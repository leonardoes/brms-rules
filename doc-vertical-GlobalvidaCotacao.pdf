0.000 g
40.00 441.89 Td
(/*Double premioPuro = capitalAssistencia >0) Tj
T* (    ? numeroVidas * capitalAssistencia * premioAssistencia\(codigoAssistencia\) / 1000) Tj
T* (    : numeroVidas * premioAssistencia\(codigoAssistencia\);*/) Tj
T* () Tj
T* (Double premioPuro = numeroVidas * premioAssistencia\(codigoAssistencia\);) Tj
T* (Double premioFinal = premioPuro * fatorCarregamento\(carregamento\) * Integer.valueOf\(periodicidadePagamento\) *) Tj
T* (fatorCnae\(cnae\);) Tj
T* () Tj
T* (return premioFinal;) Tj
